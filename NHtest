    Callback = function(state)
        MapEnabled = state
        if state then
            if not MapGui then initMap() end
            MapGui.Enabled = true
        else
            if MapGui then MapGui.Enabled = false end
            if RenderConnection then
                RenderConnection:Disconnect()
                RenderConnection = nil
            end
        end
    end
})

